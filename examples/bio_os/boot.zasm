JMP boot_start

boot_start:
    MOV R1, 1
    MOV R2, 66
    INT 80

    MOV R1, 7
    MOV R2, 8
    MOV R3, 44
    MOV R4, 888
    INT 80

    MOV R1, 5
    MOV R2, 8
    MOV R3, 44
    INT 80

    MOV R5, 0

boot_timer_wait:
    ADD R5, 1
    CMP R5, 20
    JL boot_timer_wait

    STORE [232], R5

    CALL user_program_main

    MOV R1, 3
    MOV R2, 0
    INT 80

    HALT
